# 文件上传API环境变量配置示例
# 使用方法: 
#   1. 复制此文件: cp upload.env.example upload.env
#   2. 修改 upload.env 中的值
#   3. 加载环境变量: source upload.env

# 文件上传API Key（必须修改为强密钥）
export AUTH_API_KEY="your-secret-api-key-here-change-this-in-production"

# 上传目录（可选，默认为 ./uploads）
export UPLOAD_DIR="./uploads"

# 最大文件大小，单位：字节（可选，默认为 10MB）
export UPLOAD_MAX_SIZE="10485760"

# 时间戳有效期，单位：秒（可选，默认为 300秒）
export ECHO_AUTH_TIMESTAMP_VALID="300"

